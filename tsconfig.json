{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext"],
    "moduleDetection": "force",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "pickier": ["./packages/pickier/src/index.ts"]
    },
    "resolveJsonModule": true,
    "types": ["bun"],
    "allowImportingTsExtensions": true,
    "strict": true,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedDeclarations": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true
  },
  "include": [
    "packages/pickier/src/**/*.ts",
    "packages/pickier/bin/**/*.ts",
    "packages/pickier/build.ts",
    "packages/pickier/test/**/*.ts",
    "packages/zig/**/*.ts"
  ],
  "exclude": [
    "node_modules/**/*",
    "pantry/**/*",
    "**/node_modules/**/*",
    "**/pantry/**/*",
    "packages/pickier/test/fixtures/**/*",
    "packages/pickier/test/output/**/*",
    "packages/pickier/dist/**/*",
    "packages/vscode/**/*",
    "bechmarks/**/*"
  ]
}
